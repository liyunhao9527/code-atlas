---
import { getCollection } from 'astro:content'

import { buildDomains } from '@notes/content'
import BaseLayout from '@notes/layouts/BaseLayout.astro'

const notes = await getCollection('notes')
const domains = buildDomains(notes)
const noteCount = notes.length
const groupCount = domains.reduce((count, domain) => count + domain.groups.length, 0)
---

<BaseLayout domains={domains} title="Code Atlas">
  <main class="home-main">
    <section class="hero">
      <div>
        <h1>用结构化笔记整理软件开发知识</h1>
        <p>从概念理解到示例练习，逐步建立可复用的知识体系。</p>
      </div>
    </section>

    <section class="domain-grid" aria-label="Content domains">
      {
        domains.map(domain => (
          <a class="domain-card" href={domain.entryPath}>
            <h2>{domain.label}</h2>
            <p>{domain.description}</p>
            <span class="domain-meta">{domain.notes.length} 篇笔记</span>
          </a>
        ))
      }
      <div class="domain-card">
        <h2>{noteCount} 篇笔记 / {groupCount} 个分组</h2>
        <p>内容会按主题持续补充，适合用来复习概念、查找例子和安排练习顺序。</p>
      </div>
    </section>
  </main>
</BaseLayout>
